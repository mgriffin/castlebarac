<%- content_for :title, "Change your password" %>
<section class="content">
  <h2>Change your password</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
    <%= f.hidden_field :reset_password_token %>

    <div class="mb-3">
      <%= render FormLabelComponent.new(form: f, field: "password", label: "New Password") %>
      <% if @minimum_password_length %>
        <p><em>(<%= @minimum_password_length %> characters minimum)</em></p>
      <% end %>
      <p><%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-control" %></p>
    </div>

    <div class="mb-3">
      <%= render FormLabelComponent.new(form: f, field: "password_confirmation", label: "Confirm new Password") %>
      <p><%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %></p>
    </div>

    <%= f.submit "Change my password", class: "btn btn-primary" %>
  <% end %>

  <%= render "devise/shared/links" %>
</section>
